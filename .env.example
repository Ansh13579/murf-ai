# ─── Murf AI API Key ───────────────────────────────────────────────────────
# Get your key from https://murf.ai → Dashboard → API Keys
MURF_KEY=your_murf_api_key_here

# ─── AI Chatbot (set at least one) ────────────────────────────────────────
# Groq (RECOMMENDED — free, 30 req/min): https://console.groq.com
GROQ_KEY=your_groq_api_key_here

# Gemini (fallback — free, 15 req/min): https://ai.google.dev
GEMINI_KEY=your_gemini_api_key_here

# ─── Optional ──────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=0
